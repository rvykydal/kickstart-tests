# Test the e2e functionality of global exclusive encrypted DNS functionality
# Partial tests of reqiured features are in 'certificate' and 'dns-global-bootopts'
# tests.

# Use defaults, but no network
%ksappend common/common.ks
%ksappend repos/default.ks
%ksappend l10n/default.ks
%ksappend users/default.ks
%ksappend storage/default.ks
%ksappend payload/default_packages.ks

%certificate --filename ca-bundle.crt --dir /etc/pki/dns
%ksappend data/edns-idmops.psi.redhat.com.crt
%end

%post --nochroot

# Check the presence on installed system
if [ ! -f /etc/pki/dns/ca-bundle.crt ]; then
    echo "*** ca-bundle.crt not found in /etc/pki/dns/ca-bundle.crt in installer environment" >> /root/RESULT
fi

%end

%post

# Check the presence on installed system
if [ ! -f /etc/pki/dns/ca-bundle.crt ]; then
    echo "*** ca-bundle.crt not found in /etc/pki/dns/ca-bundle.crt on installed system" >> /root/RESULT
fi


##### This is also tested in dns-global-bootopts

# Check the arguments are passed to the installed system
grep "^GRUB_CMDLINE_LINUX=" /etc/default/grub | grep "rd.net.dns=dns+tls://edns-idmops.psi.redhat.com"
if [[ $? -ne 0 ]]; then
    echo '*** Failed check: rd.net.dns option is missing' >> /root/RESULT
fi
grep "^GRUB_CMDLINE_LINUX=" /etc/default/grub | grep "rd.net.dns-resolve-mode=exclusive"
if [[ $? -ne 0 ]]; then
    echo '*** Failed check: rd.net.dns-resolve-mode option is missing' >> /root/RESULT
fi

grep "^GRUB_CMDLINE_LINUX=" /etc/default/grub | grep "rd.net.dns-backend=dnsconfd"
if [[ $? -ne 0 ]]; then
    echo '*** Failed check: rd.net.dns-backend option is missing' >> /root/RESULT
fi

# Check the NM runtime global config file is passed to the installed system
if [[ ! -e /etc/NetworkManager/conf.d/16-global-dns.conf ]]; then
    echo '*** Failed check: NetworkManger global dns configuration file is missing' >> /root/RESULT
fi

%ksappend validation/success_if_result_empty.ks

%end
